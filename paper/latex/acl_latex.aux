\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces TokLens metrics on English Wikipedia for all unique tokenizers. Fertility = tokens per word (lower is better). CPT = characters per token (higher is better). CR = compression ratio in bytes per token (higher is better). STRR = single-token retention rate (higher is better). NSL = normalized sequence length (lower is better).}}{12}{table.caption.29}\protected@file@percent }
\newlabel{tab:english_metrics}{{4}{12}{TokLens metrics on English Wikipedia for all unique tokenizers. Fertility = tokens per word (lower is better). CPT = characters per token (higher is better). CR = compression ratio in bytes per token (higher is better). STRR = single-token retention rate (higher is better). NSL = normalized sequence length (lower is better)}{table.caption.29}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces Cross-lingual parity ratios for non-Latin languages (token count / English token count). Models with shared tokenizers (Phi-3 = Llama-2, Phi-4/OLMo-2/StableLM-2 share similar 100K vocabs, Qwen2.5 family identical) are listed once. Values above 3.0 indicate substantial disadvantage for non-English users.}}{12}{table.caption.30}\protected@file@percent }
\newlabel{tab:parity}{{5}{12}{Cross-lingual parity ratios for non-Latin languages (token count / English token count). Models with shared tokenizers (Phi-3 = Llama-2, Phi-4/OLMo-2/StableLM-2 share similar 100K vocabs, Qwen2.5 family identical) are listed once. Values above 3.0 indicate substantial disadvantage for non-English users}{table.caption.30}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Single-Token Retention Rate (STRR) across tokenizers and languages. Higher values indicate more words are kept as single tokens. English and Romance languages have high STRR; Arabic, Hindi, and Thai have extremely low STRR across all tokenizers, reflecting both morphological complexity and vocabulary allocation bias.}}{13}{figure.caption.31}\protected@file@percent }
\newlabel{fig:strr}{{9}{13}{Single-Token Retention Rate (STRR) across tokenizers and languages. Higher values indicate more words are kept as single tokens. English and Romance languages have high STRR; Arabic, Hindi, and Thai have extremely low STRR across all tokenizers, reflecting both morphological complexity and vocabulary allocation bias}{figure.caption.31}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Selected Spearman correlations between TokLens metrics and benchmarks ($n=22$, 77 total comparisons). ``avg'' = average across 15 languages; ``en'' = English only. Bonferroni threshold $\alpha = 0.00065$. No correlation is statistically significant. Full results are available in the supplementary material.}}{13}{table.caption.32}\protected@file@percent }
\newlabel{tab:full_corr}{{6}{13}{Selected Spearman correlations between TokLens metrics and benchmarks ($n=22$, 77 total comparisons). ``avg'' = average across 15 languages; ``en'' = English only. Bonferroni threshold $\alpha = 0.00065$. No correlation is statistically significant. Full results are available in the supplementary material}{table.caption.32}{}}
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Linear mixed-effects model results. $\beta $: fixed effect of z-scored metric. Model random intercept variance ranges from 100 to 115, confirming that model identity explains most variance. Log(params) is significant ($p < 0.04$) in all models. All metrics except fertility reach significance ($p < 0.05$), with STRR, CPT, NSL, and parity surviving Bonferroni correction.}}{14}{table.caption.33}\protected@file@percent }
\newlabel{tab:lme}{{7}{14}{Linear mixed-effects model results. $\beta $: fixed effect of z-scored metric. Model random intercept variance ranges from 100 to 115, confirming that model identity explains most variance. Log(params) is significant ($p < 0.04$) in all models. All metrics except fertility reach significance ($p < 0.05$), with STRR, CPT, NSL, and parity surviving Bonferroni correction}{table.caption.33}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Qwen2.5 MMLU-ProX scaling curves. Each line is a language; all models share the same tokenizer. Languages with better tokenizer quality (en, fr, es) consistently score higher and show steeper scaling.}}{14}{figure.caption.34}\protected@file@percent }
\newlabel{fig:qwen_scaling}{{10}{14}{Qwen2.5 MMLU-ProX scaling curves. Each line is a language; all models share the same tokenizer. Languages with better tokenizer quality (en, fr, es) consistently score higher and show steeper scaling}{figure.caption.34}{}}
\@LN@col{2}
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Per-language scaling slope (score gain per decade of model size) vs.\ TokLens metrics for Qwen2.5. STRR shows the strongest correlation ($\rho = +0.91$, $p < 0.001$): languages with higher single-token retention benefit more from scaling. Hindi (STRR = 0.04) gains 25.8 points per decade vs.\ 34.9 for English (STRR = 0.64).}}{15}{figure.caption.35}\protected@file@percent }
\newlabel{fig:slope_metric}{{11}{15}{Per-language scaling slope (score gain per decade of model size) vs.\ TokLens metrics for Qwen2.5. STRR shows the strongest correlation ($\rho = +0.91$, $p < 0.001$): languages with higher single-token retention benefit more from scaling. Hindi (STRR = 0.04) gains 25.8 points per decade vs.\ 34.9 for English (STRR = 0.64)}{figure.caption.35}{}}
