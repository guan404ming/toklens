\newlabel{app:correlations}{{H}{15}{Full Correlation Results}{appendix.H}{}}
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Selected Spearman correlations between TokLens metrics and benchmarks ($n=22$, 77 total comparisons). ``avg'' = average across 15 languages; ``en'' = English only. Bonferroni threshold $\alpha = 0.00065$. No correlation is statistically significant.}}{15}{table.caption.31}\protected@file@percent }
\newlabel{tab:full_corr}{{7}{15}{Selected Spearman correlations between TokLens metrics and benchmarks ($n=22$, 77 total comparisons). ``avg'' = average across 15 languages; ``en'' = English only. Bonferroni threshold $\alpha = 0.00065$. No correlation is statistically significant}{table.caption.31}{}}
