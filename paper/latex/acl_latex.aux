\@writefile{toc}{\contentsline {section}{\numberline {A}Benchmark Scores}{10}{appendix.A}\protected@file@percent }
\newlabel{app:benchmarks}{{A}{10}{Benchmark Scores}{appendix.A}{}}
\@writefile{lot}{\contentsline {table}{\numberline {3}{\ignorespaces Open LLM Leaderboard v2 benchmark scores for all 22 models with leaderboard entries, sorted by parameter count. All scores are sourced from the official leaderboard. MATH = MATH Lvl 5. Avg = unweighted average of all six benchmarks.}}{10}{table.caption.24}\protected@file@percent }
\newlabel{tab:benchmarks}{{3}{10}{Open LLM Leaderboard v2 benchmark scores for all 22 models with leaderboard entries, sorted by parameter count. All scores are sourced from the official leaderboard. MATH = MATH Lvl 5. Avg = unweighted average of all six benchmarks}{table.caption.24}{}}
