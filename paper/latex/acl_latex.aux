\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Per-language scaling slope (score gain per decade of model size) vs.\ TokLens metrics for Qwen2.5. STRR shows the strongest correlation ($\rho = +0.91$, $p < 0.001$): languages with higher single-token retention benefit more from scaling. Hindi (STRR = 0.04) gains 25.8 points per decade vs.\ 34.9 for English (STRR = 0.64).}}{7}{figure.caption.16}\protected@file@percent }
\newlabel{fig:slope_metric}{{5}{7}{Per-language scaling slope (score gain per decade of model size) vs.\ TokLens metrics for Qwen2.5. STRR shows the strongest correlation ($\rho = +0.91$, $p < 0.001$): languages with higher single-token retention benefit more from scaling. Hindi (STRR = 0.04) gains 25.8 points per decade vs.\ 34.9 for English (STRR = 0.64)}{figure.caption.16}{}}
\@LN@col{1}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Correlation between TokLens metrics and MMLU-ProX scores across 7 models and 11 languages. Stars: * $p < 0.05$, ** $p < 0.01$, *** $p < 0.001$. Partial correlations control for model size. Unlike English-only analysis, several metrics significantly predict multilingual performance.}}{7}{figure.caption.18}\protected@file@percent }
\newlabel{fig:multilingual}{{6}{7}{Correlation between TokLens metrics and MMLU-ProX scores across 7 models and 11 languages. Stars: * $p < 0.05$, ** $p < 0.01$, *** $p < 0.001$. Partial correlations control for model size. Unlike English-only analysis, several metrics significantly predict multilingual performance}{figure.caption.18}{}}
