\@writefile{toc}{\contentsline {section}{\numberline {B}English Tokenizer Metrics}{10}{appendix.B}\protected@file@percent }
\newlabel{app:english}{{B}{10}{English Tokenizer Metrics}{appendix.B}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces TokLens metrics on English Wikipedia for all unique tokenizers. Qwen2.5 sizes share a single tokenizer and are listed once. Fertility = tokens per word (lower is better). CPT = characters per token (higher is better). CR = compression ratio in bytes per token (higher is better). STRR = single-token retention rate (higher is better). NSL = normalized sequence length (lower is better).}}{10}{table.caption.25}\protected@file@percent }
\newlabel{tab:english_metrics}{{4}{10}{TokLens metrics on English Wikipedia for all unique tokenizers. Qwen2.5 sizes share a single tokenizer and are listed once. Fertility = tokens per word (lower is better). CPT = characters per token (higher is better). CR = compression ratio in bytes per token (higher is better). STRR = single-token retention rate (higher is better). NSL = normalized sequence length (lower is better)}{table.caption.25}{}}
\@LN{541}{10}
\@writefile{toc}{\contentsline {section}{\numberline {C}Cross-lingual Parity}{11}{appendix.C}\protected@file@percent }
\newlabel{app:parity}{{C}{11}{Cross-lingual Parity}{appendix.C}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5}{\ignorespaces Cross-lingual parity ratios for non-Latin languages (token count / English token count). Models with shared tokenizers (Phi-3 = Llama-2, Phi-4/OLMo-2/StableLM-2 share similar 100K vocabs, Qwen2.5 family identical) are listed once. Values above 3.0 indicate substantial disadvantage for non-English users.}}{11}{table.caption.26}\protected@file@percent }
\newlabel{tab:parity}{{5}{11}{Cross-lingual parity ratios for non-Latin languages (token count / English token count). Models with shared tokenizers (Phi-3 = Llama-2, Phi-4/OLMo-2/StableLM-2 share similar 100K vocabs, Qwen2.5 family identical) are listed once. Values above 3.0 indicate substantial disadvantage for non-English users}{table.caption.26}{}}
\@LN{542}{10}
\@writefile{toc}{\contentsline {section}{\numberline {D}LME Results}{11}{appendix.D}\protected@file@percent }
\newlabel{app:lme}{{D}{11}{LME Results}{appendix.D}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6}{\ignorespaces Linear mixed-effects model results. Each model: score $\sim $ z(metric) + log(params) + (1$|$model), fitted with REML on 77 observations (7 models, 11 languages). $\beta $: fixed effect of z-scored metric. Model random intercept variance ranges from 100 to 115. All metrics except fertility reach significance ($p < 0.05$), with STRR, CPT, NSL, and parity surviving Bonferroni correction.}}{11}{table.caption.27}\protected@file@percent }
\newlabel{tab:lme}{{6}{11}{Linear mixed-effects model results. Each model: score $\sim $ z(metric) + log(params) + (1$|$model), fitted with REML on 77 observations (7 models, 11 languages). $\beta $: fixed effect of z-scored metric. Model random intercept variance ranges from 100 to 115. All metrics except fertility reach significance ($p < 0.05$), with STRR, CPT, NSL, and parity surviving Bonferroni correction}{table.caption.27}{}}
\@LN{543}{11}
\@writefile{toc}{\contentsline {section}{\numberline {E}Fertility Heatmap}{12}{appendix.E}\protected@file@percent }
\newlabel{app:fertility}{{E}{12}{Fertility Heatmap}{appendix.E}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Fertility (tokens per word) across 24 tokenizers and 15 languages. CJK languages and Thai show the largest variation. Newer tokenizers with larger vocabularies dramatically reduce fertility for non-Latin scripts.}}{12}{figure.caption.28}\protected@file@percent }
\newlabel{fig:fertility}{{8}{12}{Fertility (tokens per word) across 24 tokenizers and 15 languages. CJK languages and Thai show the largest variation. Newer tokenizers with larger vocabularies dramatically reduce fertility for non-Latin scripts}{figure.caption.28}{}}
\@LN{544}{12}
\@writefile{toc}{\contentsline {section}{\numberline {F}STRR Heatmap}{13}{appendix.F}\protected@file@percent }
\newlabel{app:strr}{{F}{13}{STRR Heatmap}{appendix.F}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Single-Token Retention Rate (STRR) across tokenizers and languages. Higher values indicate more words are kept as single tokens. English and Romance languages have high STRR; Arabic, Hindi, and Thai have extremely low STRR across all tokenizers, reflecting both morphological complexity and vocabulary allocation bias.}}{13}{figure.caption.29}\protected@file@percent }
\newlabel{fig:strr}{{9}{13}{Single-Token Retention Rate (STRR) across tokenizers and languages. Higher values indicate more words are kept as single tokens. English and Romance languages have high STRR; Arabic, Hindi, and Thai have extremely low STRR across all tokenizers, reflecting both morphological complexity and vocabulary allocation bias}{figure.caption.29}{}}
\@LN{545}{13}
\@writefile{toc}{\contentsline {section}{\numberline {G}CPT Heatmap}{14}{appendix.G}\protected@file@percent }
\newlabel{app:cpt}{{G}{14}{CPT Heatmap}{appendix.G}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Characters per token across tokenizers and languages. Higher values indicate more compact tokenization. English consistently has the highest CPT; Chinese and Thai have the lowest for tokenizers without dedicated CJK vocabulary.}}{14}{figure.caption.30}\protected@file@percent }
\newlabel{fig:cpt}{{10}{14}{Characters per token across tokenizers and languages. Higher values indicate more compact tokenization. English consistently has the highest CPT; Chinese and Thai have the lowest for tokenizers without dedicated CJK vocabulary}{figure.caption.30}{}}
\@LN{546}{14}
